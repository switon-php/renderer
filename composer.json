{
    "name": "switon/renderer",
    "description": "Template rendering with PHP and Sword engines, themes, and Frames composition for Switon Framework",
    "type": "library",
    "keywords": [
        "switon",
        "renderer",
        "templates",
        "views"
    ],
    "homepage": "https://github.com/switon-php/renderer",
    "license": "MIT",
    "authors": [
        {
            "name": "switon",
            "email": "admin@switon.dev"
        }
    ],
    "support": {
        "source": "https://github.com/switon-php/renderer",
        "issues": "https://github.com/switon-php/renderer/issues",
        "docs": "https://docs.switon.dev/latest/renderer"
    },
    "require": {
        "php": ">=8.3",
        "psr/event-dispatcher": "^1.0",
        "switon/core": "^1.0",
        "switon/event": "^1.0",
        "switon/sync": "^1.0"
    },
    "require-dev": {
        "phpstan/phpstan": "^2.0",
        "switon/testing": "^1.0",
        "phpstan/extension-installer": "^1.4"
    },
    "config": {
        "allow-plugins": {
            "switon/composer-extra": true,
            "phpstan/extension-installer": true
        }
    },
    "autoload": {
        "psr-4": {
            "Switon\\Rendering\\": "src/"
        },
        "files": [
            "helpers.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Switon\\Rendering\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "phpstan": "@php vendor/bin/phpstan analyse",
        "test:unit": "@php vendor/bin/phpunit --configuration tests/phpunit.xml.dist --testsuite=unit --display-deprecations --display-phpunit-notices",
        "test": "@php vendor/bin/phpunit --configuration tests/phpunit.xml.dist --testsuite=all --display-deprecations --display-phpunit-notices"
    },
    "extra": {
        "switon": {
            "commands": [
                "Switon\\Rendering\\Command\\SwordCommand"
            ],
            "collectors": {
                "renderer": "Switon\\Rendering\\Inspector\\RendererCollector"
            }
        },
        "branch-alias": {
            "dev-dev": "1.0.x-dev"
        }
    }
}
